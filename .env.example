# Google OAuth Configuration (Mandatory for Multi-user login)
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
FRONTEND_PORT=3000
NEXTAUTH_URL=http://localhost:3000  # Public URL of your Next.js app
NEXT_PUBLIC_API_URL=http://localhost:8000 # Base URL for API calls from the frontend

# Google Maps API Configuration (Optional for garden location picker)
# Get one at https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Trefle.io API Configuration (Mandatory for plant search)
# Get a free token at https://trefle.io/
TREFLE_API_TOKEN=your_trefle_token_here

# AI Integration (Optional)
# OpenRouter Key for AI advice
OPENROUTER_API_KEY=your_openrouter_key_here

# Weather API (Optional)
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# Database Configuration (Used by Docker Compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tuinkalender

# Standard OpenRouter Model (Optional, default is google/gemma-3-27b-it:free)
NEXT_PUBLIC_DEFAULT_OPENROUTER_MODEL=google/gemma-3-27b-it:free